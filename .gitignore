# 01 raw and 02 trusted — local only, not synced; preserve directory structure
01 raw/**
!01 raw/**/
!01 raw/**/.gitkeep

02 trusted/**
!02 trusted/**/
!02 trusted/**/.gitkeep

# Projects — all project content may contain proprietary info; not synced, preserve directory structure
projects/**
!projects/**/
!projects/**/.gitkeep
